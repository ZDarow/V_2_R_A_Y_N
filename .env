# v2rayN Russia Setup — централизованная конфигурация
# ============================================================================
# Загружается: source .env (или lib/common.sh)
# Переопределяется переменными окружения (высший приоритет)
# ============================================================================

# --- Пути ---
V2RAYN_CONFIG_DIR="${V2RAYN_CONFIG_DIR:-$HOME/.config/v2rayN}"
V2RAYN_DATA_DIR="${V2RAYN_DATA_DIR:-$HOME/.local/share/v2rayN}"
V2RAYN_SCRIPTS_DIR="${V2RAYN_SCRIPTS_DIR:-$V2RAYN_DATA_DIR/scripts}"
V2RAYN_LOG_DIR="${V2RAYN_LOG_DIR:-$V2RAYN_DATA_DIR/logs}"
V2RAYN_LOCK_DIR="${V2RAYN_LOCK_DIR:-$V2RAYN_DATA_DIR/locks}"
V2RAYN_CACHE_DIR="${V2RAYN_CACHE_DIR:-$HOME/.cache/v2rayN}"

# --- Порты ---
SOCKS_PORT="${SOCKS_PORT:-10808}"
HTTP_PORT="${HTTP_PORT:-10809}"
XRAY_API_PORT="${XRAY_API_PORT:-62789}"

# --- URL подписок и правил ---
GEOIP_URL="${GEOIP_URL:-https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/geoip.dat}"
GEOSITE_URL="${GEOSITE_URL:-https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/geosite.dat}"

# --- Whitelist URLs (hxehex) ---
HXEHEX_CIDR_URL="${HXEHEX_CIDR_URL:-https://raw.githubusercontent.com/hxehex/russia-mobile-internet-whitelist/main/cidrwhitelist.txt}"
HXEHEX_IP_URL="${HXEHEX_IP_URL:-https://raw.githubusercontent.com/hxehex/russia-mobile-internet-whitelist/main/ipwhitelist.txt}"
HXEHEX_SNI_URL="${HXEHEX_SNI_URL:-https://raw.githubusercontent.com/hxehex/russia-mobile-internet-whitelist/main/whitelist.txt}"

# --- Белые SNI домены для ротации ---
SNI_WHITELIST=(
    "yandex.ru" "vk.com" "mail.ru" "gosuslugi.ru"
    "ok.ru" "rkn.gov.ru" "xn--80af2al1c.xn--p1ai"
    "sberbank.ru" "mos.ru" "nalog.ru" "cbr.ru"
)

# --- Подписки igareck ---
IGARECK_BASE="${IGARECK_BASE:-https://raw.githubusercontent.com/igareck/vpn-configs-for-russia/main}"
IGARECK_MIRRORS=(
    "https://gitlab.com/igareck/vpn-configs-for-russia"
    "https://codeberg.org/igareck/vpn-configs-for-russia"
    "https://gitea.com/igareck/vpn-configs-for-russia"
)

# --- Xray-core ---
XRAY_EXEC="${XRAY_EXEC:-xray}"
XRAY_CONFIG="${XRAY_CONFIG:-$V2RAYN_CONFIG_DIR/config.json}"

# --- Сеть ---
MTU_MOBILE="${MTU_MOBILE:-1360}"
MTU_WIFI="${MTU_WIFI:-1500}"
