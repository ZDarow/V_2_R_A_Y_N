{
  "_warning": "⚠️ Xray-core ОТКЛЮЧАЕТ allowInsecure с 1 августа 2026.",
  "_fix": "В настройках подписки v2rayN: ✏️ → Отпечаток сертификата → Вкл (pinnedPeerCertSha256)",
  "_example_pinned": "'pinnedPeerCertSha256': ['SHA256-отпечаток сертификата вашего сервера'] — получите из v2rayNG/лога подключения",
  "_policy_comments": {
    "handshake": "4с — таймаут рукопожатия TLS (баланс скорости и надёжности)",
    "connIdle": "120с — время простоя до закрытия соединения (экономия памяти)",
    "uplinkOnly": "1с — задержка закрытия аплинк-канала после ответа сервера",
    "downlinkOnly": "2с — задержка закрытия даунлинк-канала (для keep-alive)",
    "bufferSize": "512 — размер буфера на соединение (512+ включает mux.cool)"
  },
  "policy": {
    "levels": {
      "0": {
        "handshake": 4,
        "connIdle": 120,
        "uplinkOnly": 1,
        "downlinkOnly": 2,
        "bufferSize": 512
      }
    },
    "system": {
      "statsInboundUplink": false,
      "statsInboundDownlink": false,
      "statsOutboundUplink": false,
      "statsOutboundDownlink": false
    }
  },
  "_dns_comments": "DNS-over-HTTPS резолверы с явным маппингом имён → IP. Прямой резолвинг DNS-имён через прокси (dns.google, dns.yandex.net) позволяет обходить блокировки DoH на уровне IP.",
  "dns": {
    "hosts": {
      "dns.google": [
        "8.8.8.8",
        "8.8.4.4"
      ],
      "dns.cloudflare.com": [
        "1.1.1.1",
        "1.0.0.1"
      ],
      "dns.yandex.net": [
        "77.88.8.8",
        "77.88.8.1"
      ],
      "dns.technic.su": [
        "185.238.130.141",
        "2a0a:1f44::1"
      ]
    },
    "servers": [
      "https://dns.google/dns-query",
      "https://cloudflare-dns.com/dns-query",
      "https://dns.yandex.ru/dns-query",
      "https://dns.technic.su/dns-query",
      "localhost"
    ],
    "queryStrategy": "UseIP",
    "disableCache": false,
    "disableFallback": false
  },
  "inbounds": [
    {
      "port": 10808,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    },
    {
      "port": 10809,
      "protocol": "http",
      "settings": {
        "auth": "noauth"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {},
      "tag": "direct",
      "_stream_comments": "sockopt: tcpFastOpen=true — ускорение TLS (экономит 1 RTT); tcpKeepAliveIdle=45с — интервал keep-alive; tcpKeepAliveInterval=15с — частота проверок; tcpUserTimeout=10000мс — таймаут подтверждения; domainStrategy=UseIP — использовать IP напрямую; tcpcongestion=bbr — алгоритм контроля перегрузки",
      "streamSettings": {
        "sockopt": {
          "tcpFastOpen": true,
          "tcpKeepAliveIdle": 45,
          "tcpKeepAliveInterval": 15,
          "tcpUserTimeout": 10000,
          "domainStrategy": "UseIP",
          "tcpcongestion": "bbr"
        }
      }
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    },
    {
      "_proxy_comments": "Фрагментация handshake TLS для обхода DPI. packets=tlshello — только начало TLS-сессии; length=100-200 байт — размер фрагмента; interval=10-20мс — пауза между фрагментами (имитация реального TCP-трафика)",
      "protocol": "freedom",
      "settings": {
        "fragment": {
          "packets": "tlshello",
          "length": "100-200",
          "interval": "10-20"
        }
      },
      "tag": "proxy",
      "streamSettings": {
        "sockopt": {
          "tcpFastOpen": true,
          "tcpKeepAliveIdle": 45,
          "tcpKeepAliveInterval": 15,
          "tcpUserTimeout": 10000,
          "domainStrategy": "UseIP",
          "tcpcongestion": "bbr"
        }
      }
    }
  ],
  "routing": {
    "domainStrategy": "IPOnDemand",
    "domainMatcher": "hybrid",
    "rules": [
      {
        "type": "field",
        "domain": [
          "geosite:category-ads-all"
        ],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru-whitelist"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "domain": [
          "geosite:ru-available-only-inside"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "direct"
      }
    ]
  }
}
