{
  "domainStrategy": "IPIfNonMatch",
  "domainMatcher": "hybrid",
  "rules": [
    {
      "type": "field",
      "domain": ["geosite:category-ads-all"],
      "outboundTag": "block"
    },
    {
      "type": "field",
      "domain": ["geosite:ru-blocked"],
      "outboundTag": "proxy"
    },
    {
      "type": "field",
      "ip": ["geoip:ru-blocked"],
      "outboundTag": "proxy"
    },
    {
      "type": "field",
      "ip": ["1.0.0.1", "1.1.1.1", "8.8.8.8", "8.8.4.4"],
      "outboundTag": "proxy"
    },
    {
      "type": "field",
      "network": "udp",
      "port": "50000-65535",
      "outboundTag": "proxy"
    },
    {
      "type": "field",
      "ip": ["geoip:ru"],
      "outboundTag": "direct"
    },
    {
      "type": "field",
      "domain": ["domain:ru", "domain:su", "domain:xn--p1ai",
