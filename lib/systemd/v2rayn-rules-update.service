[Unit]
Description=v2rayN Russia — обновление geoip/geosite правил
Documentation=https://github.com/ZDarow/V_2_R_A_Y_N
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=%h/.local/share/v2rayN/scripts/update-rules.sh
StandardOutput=journal
StandardError=journal
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.local/share/v2rayN %h/.cache/v2rayN
